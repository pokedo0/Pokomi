CREATE TABLE author_subscription_result_cache(
    subscription_id INTEGER NOT NULL REFERENCES author_subscription(_id) ON DELETE CASCADE,
    cached_at INTEGER NOT NULL,
    result_count INTEGER NOT NULL,
    PRIMARY KEY(subscription_id)
);

CREATE TABLE author_subscription_result_cache_manga(
    subscription_id INTEGER NOT NULL REFERENCES author_subscription_result_cache(subscription_id) ON DELETE CASCADE,
    manga_id INTEGER NOT NULL REFERENCES mangas(_id) ON DELETE CASCADE,
    position INTEGER NOT NULL,
    PRIMARY KEY(subscription_id, manga_id)
);

CREATE INDEX author_subscription_result_cache_manga_subscription_index
ON author_subscription_result_cache_manga(subscription_id, position);

selectBySubscriptionIds:
SELECT *
FROM author_subscription_result_cache
WHERE subscription_id IN :subscriptionIds;

selectMangasBySubscriptionIds:
SELECT
    author_subscription_result_cache_manga.subscription_id,
    mangas.*
FROM author_subscription_result_cache_manga
JOIN mangas
ON mangas._id = author_subscription_result_cache_manga.manga_id
WHERE author_subscription_result_cache_manga.subscription_id IN :subscriptionIds
ORDER BY
    author_subscription_result_cache_manga.subscription_id,
    author_subscription_result_cache_manga.position;

deleteBySubscriptionId:
DELETE FROM author_subscription_result_cache
WHERE subscription_id = :subscriptionId;

insert:
INSERT INTO author_subscription_result_cache(
    subscription_id,
    cached_at,
    result_count
)
VALUES (
    :subscriptionId,
    :cachedAt,
    :resultCount
);

insertManga:
INSERT INTO author_subscription_result_cache_manga(
    subscription_id,
    manga_id,
    position
)
VALUES (
    :subscriptionId,
    :mangaId,
    :position
);
